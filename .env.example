# ─── Panchayat Environment Variables ─────────────────────────────────────
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env

# MongoDB Connection (Required)
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority

# Google Gemini API Key (Required for LangGraph engine)
GOOGLE_API_KEY=your_gemini_api_key_here

# Groq API Key (Required for NPC dialogue & sabotage evaluation)
GROQ_API_KEY=your_groq_api_key_here

# ElevenLabs API Key (Required for character voice TTS)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ArmorIQ API Key (Optional — Election Commissioner moderation)
ARMORIQ_API_KEY=your_armoriq_api_key_here